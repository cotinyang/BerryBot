# 语音助手服务端配置
# 复制为 .env 并修改: cp .env.example .env

# TLS 证书（Let's Encrypt 路径，改成你的域名）
TLS_CERT=/etc/letsencrypt/live/your-domain.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/your-domain.com/privkey.pem

# 认证 token（务必改成你自己的随机字符串，两端必须一致）
# 生成方法: openssl rand -hex 32
AUTH_TOKEN=change-me-to-a-random-secret

# 服务监听
HOST=0.0.0.0
PORT=8765

# Whisper 模型大小: tiny / base / small / medium / large
WHISPER_MODEL=base

# TTS 语音角色
TTS_VOICE=zh-CN-XiaoxiaoNeural

# TTS 流式策略
# 1=true 按句合成并连续推流（推荐，可减轻长段中途卡顿）
# 0=false 整段一次性合成
TTS_SENTENCE_STREAM=1
# 按句模式下单段最大字符数（超长句会继续切块）
TTS_SENTENCE_MAX_CHARS=80

# Soul / Memory 文件路径
SOUL_PATH=SOUL.md
MEMORY_PATH=MEMORY.md

# 调试开关: 1=true, 0=false
# 开启后跳过 Agent，语音识别文本直接做 TTS 回传（用于链路联调）
DEBUG_BYPASS_AGENT=0

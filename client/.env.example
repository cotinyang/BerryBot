# 语音助手客户端配置
# 复制为 .env 并修改: cp .env.example .env

# 服务端地址（改成你的 VPS 域名）
SERVER_URL=wss://your-domain.com:8765

# 认证 token（必须与服务端一致）
AUTH_TOKEN=change-me-to-a-random-secret

# 唤醒词引擎: sherpa_onnx (默认，免费开源) 或 porcupine (需要 Picovoice 账号)
WAKE_WORD_ENGINE=sherpa_onnx

# Sherpa-onnx 配置（默认引擎）
WAKE_WORD_KEYWORDS=小艺小艺
# WAKE_WORD_MODEL_PATH=          # 留空自动下载

# Porcupine 配置（可选引擎）
# WAKE_WORD_ACCESS_KEY=your-porcupine-access-key
# WAKE_WORD_KEYWORD_PATH=/path/to/keyword.ppn

# 唤醒提示音
WAKE_PROMPT_AUDIO=assets/wo_zai.mp3
WAKE_PROMPT_DELAY=0.3

# 音频参数
SILENCE_THRESHOLD=1.5
SAMPLE_RATE=16000
ENERGY_THRESHOLD=500.0

# 重连参数
RECONNECT_INTERVAL=5.0
MAX_RECONNECT_RETRIES=3

# 连续对话
SESSION_TIMEOUT=5.0
SESSION_END_AUDIO=assets/end.wav

# 音频播放（树莓派蓝牙音箱可配置）
# 自定义播放命令，支持 {file} 占位符。
# 例如：AUDIO_PLAYER_COMMAND=mpg123 -q -a bluealsa {file}
AUDIO_PLAYER_COMMAND=

# 播放设备名称（当使用内置 mpg123/aplay 时生效）
# 例如：AUDIO_OUTPUT_DEVICE=bluealsa
AUDIO_OUTPUT_DEVICE=

# ── 树莓派音频噪音抑制 ────────────────────────────────
# 抑制 ALSA/JACK 在 PortAudio 初始化时打印的设备探测错误日志。
# ALSA 噪音由 conftest.py（测试）和 main.py（运行时）通过 ctypes 处理。
# JACK 噪音：建议直接卸载 libjack（sudo apt remove libjack-jackd2-0）
# 或启用下面的变量（仅对部分 JACK 版本有效）：
# JACK_NO_AUDIO_RESERVATION=1

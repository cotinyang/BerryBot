# 语音助手客户端配置
# 复制为 .env 并修改: cp .env.example .env

# 服务端地址（改成你的 VPS 域名）
SERVER_URL=wss://your-domain.com:8765

# 认证 token（必须与服务端一致）
AUTH_TOKEN=change-me-to-a-random-secret

# Porcupine 唤醒词引擎
# 访问密钥: https://console.picovoice.ai/ 注册获取
WAKE_WORD_ACCESS_KEY=your-porcupine-access-key
# 唤醒词模型文件路径
WAKE_WORD_KEYWORD_PATH=/path/to/keyword.ppn

# 唤醒提示音
WAKE_PROMPT_AUDIO=assets/wo_zai.wav
WAKE_PROMPT_DELAY=0.3

# 音频参数
SILENCE_THRESHOLD=1.5
SAMPLE_RATE=16000
ENERGY_THRESHOLD=500.0

# 重连参数
RECONNECT_INTERVAL=5.0
MAX_RECONNECT_RETRIES=3
